### Endpoints para probar OSRM - ms-localizaciones

### 1. Calcular ruta completa entre Córdoba y Rosario
# Córdoba: -64.18105, -31.4135
# Rosario: -60.6985, -32.9471
GET http://localhost:8087/api/osrm/calcular-distancia?origenLong=-64.18105&origenLat=-31.4135&destinoLong=-60.6985&destinoLat=-32.9471
Accept: application/json

### 2. Calcular solo distancia en km entre Córdoba y Rosario
GET http://localhost:8087/api/osrm/distancia-km?origenLong=-64.18105&origenLat=-31.4135&destinoLong=-60.6985&destinoLat=-32.9471
Accept: application/json

### 3. Calcular ruta entre Buenos Aires y La Plata
# Buenos Aires: -58.3816, -34.6037
# La Plata: -57.9545, -34.9215
GET http://localhost:8087/api/osrm/calcular-distancia?origenLong=-58.3816&origenLat=-34.6037&destinoLong=-57.9545&destinoLat=-34.9215
Accept: application/json

### 4. Calcular distancia en km entre Buenos Aires y Mendoza
# Buenos Aires: -58.3816, -34.6037
# Mendoza: -68.8458, -32.8895
GET http://localhost:8087/api/osrm/distancia-km?origenLong=-58.3816&origenLat=-34.6037&destinoLong=-68.8458&destinoLat=-32.8895
Accept: application/json

