### OSRM - Ejemplos de Uso de la API
### Microservicio de Localizaciones - Cálculo de Distancias

@baseUrl = http://localhost:8082
@latCordoba = -31.4135
@lonCordoba = -64.18105
@latRosario = -32.9471
@lonRosario = -60.6985
@latBuenosAires = -34.6037
@lonBuenosAires = -58.3816

###
# 1. Calcular distancia simple (Córdoba -> Rosario)
GET {{baseUrl}}/api/osrm/distancia?latOrigen={{latCordoba}}&lonOrigen={{lonCordoba}}&latDestino={{latRosario}}&lonDestino={{lonRosario}}

###
# 2. Calcular distancia forzando recálculo
GET {{baseUrl}}/api/osrm/distancia?latOrigen={{latCordoba}}&lonOrigen={{lonCordoba}}&latDestino={{latRosario}}&lonDestino={{lonRosario}}&forzarRecalculo=true

###
# 3. Calcular distancia con detalles de ruta completa
GET {{baseUrl}}/api/osrm/ruta?latOrigen={{latCordoba}}&lonOrigen={{lonCordoba}}&latDestino={{latRosario}}&lonDestino={{lonRosario}}

###
# 4. Verificar disponibilidad de OSRM
GET {{baseUrl}}/api/osrm/health

###
# 5. Limpiar caché expirado
DELETE {{baseUrl}}/api/osrm/cache/limpiar

###
# 6. Ejemplo predefinido (Córdoba -> Rosario)
GET {{baseUrl}}/api/osrm/ejemplo

###
# 7. Córdoba -> Buenos Aires
GET {{baseUrl}}/api/osrm/distancia?latOrigen={{latCordoba}}&lonOrigen={{lonCordoba}}&latDestino={{latBuenosAires}}&lonDestino={{lonBuenosAires}}

###
# 8. Rosario -> Buenos Aires
GET {{baseUrl}}/api/osrm/distancia?latOrigen={{latRosario}}&lonOrigen={{lonRosario}}&latDestino={{latBuenosAires}}&lonDestino={{lonBuenosAires}}

